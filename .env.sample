GOOGLE_MAPS_API_KEY=key
NUXT_PUBLIC_GOOGLE_MAPS_API_KEY=key (but should be okay to use in public)
NUXT_PUBLIC_GOOGLE_MAPS_MAP_ID=1110d0dace06c35
BROWSERLESS_URL=browserless.lksfr.de
BROWSERLESS_TOKEN=token
CRON_TOKEN=supersecrettoken
LOCAL_SQLITE_PATH=
OPENAI_API_KEY=key

# Better Auth (admin): secret ≥32 chars; URL must match the site origin (e.g. DEPLOYMENT_URL).
BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000
# One-time: after migrations, run `bun seed:admin` with SEED_ADMIN_PASSWORD set.
# Optional: SEED_ADMIN_EMAIL, SEED_ADMIN_USERNAME, SEED_ADMIN_NAME

# Imgproxy configuration for image processing
IMGPROXY_ENDPOINT=https://your-imgproxy-instance.com
IMGPROXY_KEY=your-imgproxy-key
IMGPROXY_SALT=your-imgproxy-salt

