# Google Maps (Cloud Console → Credentials / Map Management)
GOOGLE_MAPS_API_KEY=
NUXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NUXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# SQLite path, e.g. ./server/db/sqlite.db
LOCAL_SQLITE_PATH=

# Better Auth (≥32 chars). Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public origin, no trailing slash (default http://localhost:3000)
# DEPLOYMENT_URL=http://localhost:3000

# Optional scraper batch size (default 40, max 500)
# ADMIN_SCRAPER_EXTRACT_BATCH=40

# Telegram (all three to enable; leave unset to disable)
# TELEGRAM_BOT_TOKEN=          # from @BotFather
# TELEGRAM_BOT_USERNAME=       # without @
# TELEGRAM_WEBHOOK_SECRET=     # openssl rand -hex 32; required in prod

# One-time admin seed: SEED_ADMIN_PASSWORD='…' bun seed:admin
# SEED_ADMIN_PASSWORD=
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_NAME=Admin
