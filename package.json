{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "packageManager": "^bun@1.2.0",
  "scripts": {
    "build": "bun --bun nuxt build",
    "dev": "bun --bun nuxt dev",
    "generate": "bun --bun nuxt generate",
    "preview": "bun --bun nuxt preview",
    "start": "bun run .output/server/index.mjs",
    "db:generate": "bun --bun drizzle-kit generate",
    "db:migrate": "bun --bun server/db/migrate.ts",
    "db:push": "bun --bun drizzle-kit push",
    "db:studio": "bun --bun drizzle-kit studio",
    "seed:admin": "bun --bun scripts/seed-admin-auth.ts",
    "scrape:canary": "bun --bun scripts/scraper-canary.ts",
    "typecheck": "bun vue-tsc -b --noEmit",
    "test": "bun test",
    "postinstall": "bun --bun nuxt prepare"
  },
  "dependencies": {
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "@nuxt/image": "^2.0.0-alpha.1",
    "@t3-oss/env-nuxt": "^0.13.11",
    "@trpc/client": "^10.45.0",
    "@trpc/server": "^10.45.0",
    "better-auth": "^1.6.23",
    "chart.js": "^4.5.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "grammy": "^1.44.0",
    "ky": "^1.14.3",
    "lottie-web": "^5.13.0",
    "node-html-parser": "^7.1.0",
    "sharp": "^0.34.5",
    "trpc-nuxt": "^0.10.17",
    "vue-chartjs": "^5.3.4",
    "vue3-google-map": "^0.27.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxt/devtools": "^4.0.0-alpha.7",
    "@nuxt/icon": "2.3.1",
    "@nuxtjs/eslint-config-typescript": "^12.1.0",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/sitemap": "^8.2.2",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/bun": "^1.3.14",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@unhead/vue": "^2.1.2",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.9.2",
    "nuxt": "^4.4.8",
    "nuxt-ipx-cache": "1.0.8",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "typescript": "^6.0.3",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "vue-tsc": "^3.3.7"
  },
  "overrides": {
    "caniuse-lite": "1.0.30001803",
    "esbuild": "^0.25.0",
    "sharp": "0.34.5"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "esbuild",
    "sharp",
    "unrs-resolver"
  ]
}
